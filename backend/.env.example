# ----- Admin (fixed, predefined credentials) -----
ADMIN_EMAIL=admin@recruit.ai
ADMIN_PASSWORD=Admin@123

# ----- Auth tokens -----
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_HOURS=12

# ----- LLM backend: OpenAI-compatible vLLM server on a remote GPU host -----
# Point this at the machine running vLLM. The /v1 suffix is appended if omitted.
VLLM_BASE_URL=http://172.20.7.22:8000
VLLM_MODEL=gemma4-31b
VLLM_API_KEY=EMPTY

# ----- Optional: embedding model for semantic resume scoring -----
EMBEDDING_MODEL=all-MiniLM-L6-v2
